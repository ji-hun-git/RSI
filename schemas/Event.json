        "digest": {
          "title": "Digest",
          "type": "string"
        },
        "prev_digest": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prev Digest"
        },
        "producer": {
          "title": "Producer",
          "type": "string"
        },
        "sequence": {
          "title": "Sequence",
          "type": "integer"
        },
        "signature": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Signature"
        }
      },
      "required": [
        "producer",
        "digest",
        "sequence"
      ],
      "title": "Integrity",
      "type": "object"
    },
